# ─────────────────────────────────────────────────────────────
# Rail4Sight-B2C-Journey-Planner — Environment Variables
# Copy this file to .env.local and fill in your real values.
# .env.local is blocked by .gitignore and will NEVER be pushed to GitHub.
# ─────────────────────────────────────────────────────────────

# Groq API Key (server-side only — NO NEXT_PUBLIC_ prefix)
# Never expose this to the browser. It is read only inside /api/chat/route.ts
# Get your key at: https://console.groq.com
GROQ_API_KEY=

# HuggingFace Parquet dataset URL (public read, safe to expose)
# Set this after running: python api/upload_to_huggingface.py
NEXT_PUBLIC_HF_DATASET_URL=

# Python ML model service URL (optional)
# If deployed, real sklearn predictions are used instead of the JS fallback
PYTHON_MODEL_URL=
